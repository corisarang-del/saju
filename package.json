    "daisyui": "^5.5.14",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "sharp": ">=0.35.0"
    }
  }
}
