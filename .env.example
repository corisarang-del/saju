# ============================================
# 월간사주 Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Dashboard > Authentication > URL Configuration
# Site URL: http://localhost:3000
# Redirect URLs:
# - http://localhost:3000/auth/callback
# - https://your-production-domain.com/auth/callback
#
# Supabase Dashboard > Authentication > Providers > Google
# Enable Google and add the Client ID / Client Secret from Google Cloud.

# --- AI (Google Gemini) ---
# API key mode: AI_PROVIDER=google
# ADC / Google Cloud Vertex mode: AI_PROVIDER=vertex
AI_PROVIDER=vertex
AI_MODEL=gemini-2.5-flash-lite
GOOGLE_VERTEX_PROJECT=your_google_cloud_project_id
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_only_when_ai_provider_is_google

# --- Payment feature flag ---
# 비결제 베타 배포 기본값은 false다. 결제 재오픈 때 서버/브라우저 flag를 함께 true로 둔다.
PAYMENTS_ENABLED=false
NEXT_PUBLIC_PAYMENTS_ENABLED=false
REQUIRE_PADDLE_ENV=false

# --- Paddle Payment (only required when reopening payments) ---
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_10=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_10=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_30=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_30=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_70=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_70=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_STAR_PREMIUM=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_STAR_PREMIUM=your_paddle_price_id
NEXT_PUBLIC_PADDLE_PRODUCT_MONTHLY_MEMBERSHIP=your_paddle_product_id
NEXT_PUBLIC_PADDLE_PRICE_MONTHLY_MEMBERSHIP=your_paddle_price_id

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ORIGIN=http://localhost:3000
ADMIN_EMAILS=your_admin_email@example.com

# --- Rate limit ---
# local 개발은 생략하면 memory를 쓰고, production/release gate는 반드시 supabase로 둔다.
RATE_LIMIT_BACKEND=supabase

# --- Discord (Optional) ---
DISCORD_PAYMENTS_WEBHOOK_URL=your_discord_webhook_url
