NEXT_PUBLIC_PADDLE_PRICE_STAR_PREMIUM=your_paddle_price_id

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
